{
    "save_dir": "./output/demographic_classifier_age",
    "is_multi_class": true,
    "train_targets_file_path_list": [
        "../example_data/demographic_classifier/labels/TCGA-BRCA-Age.json"
    ],
    "val_test_targets_file_path_list": [
        "../example_data/demographic_classifier/labels/TCGA-BRCA-Age.json"
    ],
    "features_dir_path_list": [
        "../example_data/demographic_classifier/features"
    ],
    "model_type": "MultiClassMLPMeanPoolModel",
    "model_init_args": {
        "input_dim": 768,
        "output_dim": 2,
        "hidden_layer_dims": [64, 32, 8],
        "inter_layer_activation_function": "relu"
    },
    "metrics": [
        "SampleSize",
        "CE",
        "MicroAUC",
        "Top1Accuracy",
        "Top1BalancedAccuracy",
        "AUC_OneVOne",
        "AUC_OneVRest",
        "MultiClassConfusionMatrix",
        "MultiClassConfusionMatrixPercentage"
    ],
    "best_model_selector_metrics_list": [
        "MicroAUC",
        "Top1BalancedAccuracy"
    ],
    "tr_dataset_type": "TileLevelFeaturesDataset",
    "tr_dataset_init_args": {
        "n_tiles": 100
    },
    "class_balance": false,
    "val_test_dataset_type": null,
    "val_test_dataset_init_args": null,
    "optimizer_type": "Adam",
    "optimizer_init_args": {
        "lr": 0.00002
    },
    "loss_function": "CrossEntropyLoss",
    "loss_function_init_args": {
        "label_smoothing": 0.1
    },
    "n_epochs": 10,
    "batch_size": 2,
    "gradient_accumulation_steps": 1,
    "cross_validation_folds": null,
    "early_stopping_patience": 5,
    "val_from_train_ratio": 0.2,
    "validation_size": 0.2,
    "test_size": 0.2
}

